# terraform.tfvars — Copy to terraform.tfvars and edit values

aws_region   = "ap-northeast-2"
cluster_name = "kubeadm-lab"

# Your public IP for remote kubectl access (run: curl -s ifconfig.me)
my_ip = "203.0.113.1/32"

# Defaults below — override only if needed
# control_plane_instance_type = "t3.medium"
# worker_instance_type        = "t3.small"
# worker_count                = 2
# ebs_volume_size             = 30
# pod_network_cidr            = "10.244.0.0/16"
# kubernetes_version          = "1.31"
